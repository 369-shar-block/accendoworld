# Supabase — copy this to .env.local and fill in the values from your
# Supabase project dashboard (Project settings → API).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — used ONLY by scripts/migrate-to-supabase.mjs.
# Never commit this and never expose it to the client. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
